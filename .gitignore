# Secrets — never commit
.env
.env.local
*.pem
*.key

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
env/
venv/
.venv/

# HuggingFace / model caches (large, redownloadable)
~/.cache/huggingface/

# Source corpus — a 1.1GB clone of langchain-ai/docs at the pinned commit.
# NOT vendored: it's another MIT repo, regenerable by cloning at the pinned SHA
# (see docs/roadmap.md / README). Treated as read-only source, never committed.
data/raw/

# Local data — regenerable from data/raw/ via the pipeline
data/cleaned/
data/processed/
data/chroma/

# Private working notes — deep internal data-flow doc, not for publication.
docs/INTERNALS.md

# Learning/scratch scripts written while building each phase. Useful for
# understanding, but not part of the project's runtime — nothing imports them.
scripts/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# OS
Thumbs.db

# Claude Code local (personal) settings — machine-specific, not shared.
.claude/settings.local.json

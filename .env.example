# Copy to .env and fill in. .env is gitignored — never commit real keys.
#
#   cp .env.example .env
#
# NOTHING here is required to run the assistant itself: generation is local
# (llama3.1:8b via Ollama). These keys only unlock the cloud eval judge and
# tracing.

# --- Ollama (local LLM) -----------------------------------------------------
# Only set this if Ollama is not on the default host/port.
# OLLAMA_HOST=http://localhost:11434

# --- Gemini (EVAL ONLY) -----------------------------------------------------
# Used as the RAGAS judge and as the default guardrail verifier backend. A
# DIFFERENT model from the answerer on purpose, so it can't grade itself.
# Get one at https://aistudio.google.com/apikey  (billing on = no RPM throttling)
GEMINI_API_KEY=

# Which guardrail verifier to use: "gemini" (default) or "ollama" (fully local).
# Falls back to ollama automatically if the Gemini call fails.
# GUARDRAIL_VERIFIER=gemini

# --- LangSmith tracing (optional) -------------------------------------------
# Leave blank to run fully offline — tracing silently no-ops without a key.
# Create a key at https://smith.langchain.com → Settings → API Keys
LANGSMITH_API_KEY=

# Optional. The app auto-detects your region (US → EU → APAC) if this is unset;
# pinning it just skips that ~1-2s probe at startup.
#   US    https://api.smith.langchain.com      (default)
#   EU    https://eu.api.smith.langchain.com
#   APAC  https://apac.api.smith.langchain.com
# LANGSMITH_ENDPOINT=

# Project name shown in the LangSmith UI (defaults to "rag-build-agent").
# LANGSMITH_PROJECT=rag-build-agent
